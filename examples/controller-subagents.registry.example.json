{
  "schema_version": "0.1",
  "updated_at": "2026-06-01",
  "common_runtime_root": "./runtime",
  "goals": [
    {
      "id": "example-controller-goal",
      "domain": "complex-project-control-plane",
      "status": "active",
      "role": "controller",
      "parent_goal_id": null,
      "repo": "/path/to/project",
      "state_file": ".codex/goals/example-controller-goal/ACTIVE_GOAL_STATE.md",
      "authority_sources": [
        {
          "kind": "goal_doc",
          "path": "docs/GOAL.md",
          "role": "primary_goal_document"
        }
      ],
      "adapter": {
        "kind": "controller_pre_tick_v0",
        "status": "connected"
      },
      "spawn_policy": {
        "mode": "multi_subagent",
        "allowed": true,
        "max_children": 3,
        "allowed_domains": [
          "docs-map",
          "validation-map",
          "implementation-slice"
        ]
      },
      "coordination": {
        "write_scope": [
          "docs/**",
          "examples/**",
          "src/adapters/**"
        ],
        "claim_ttl_minutes": 30,
        "requires_parent_approval": [
          "write",
          "publish",
          "production-action"
        ]
      },
      "next_probe": "python3 scripts/controller-pre-tick.py --format json --save-run",
      "guards": [
        "controller owns merge decisions",
        "sub-agents must declare work_scope before acting",
        "overlapping write scopes require parent arbitration"
      ]
    },
    {
      "id": "example-docs-map-subagent",
      "domain": "docs-map",
      "status": "planned",
      "role": "subagent",
      "parent_goal_id": "example-controller-goal",
      "repo": "/path/to/project",
      "state_file": ".codex/goals/example-docs-map-subagent/ACTIVE_GOAL_STATE.md",
      "adapter": {
        "kind": "read_only_explorer_v0",
        "status": "planned"
      },
      "coordination": {
        "write_scope": [],
        "claim_ttl_minutes": 15,
        "requires_parent_approval": [
          "write"
        ]
      },
      "next_probe": "inspect docs and return a task map; do not edit files",
      "guards": [
        "read-only",
        "return evidence paths and residual risk",
        "do not mark the parent goal complete"
      ]
    },
    {
      "id": "example-validation-subagent",
      "domain": "validation-map",
      "status": "planned",
      "role": "subagent",
      "parent_goal_id": "example-controller-goal",
      "repo": "/path/to/project",
      "state_file": ".codex/goals/example-validation-subagent/ACTIVE_GOAL_STATE.md",
      "adapter": {
        "kind": "validator_v0",
        "status": "planned"
      },
      "coordination": {
        "write_scope": [],
        "claim_ttl_minutes": 15,
        "requires_parent_approval": [
          "write"
        ]
      },
      "next_probe": "run validation commands and report pass/fail without edits",
      "guards": [
        "read-only",
        "include command names and failure summaries",
        "do not publish raw private logs"
      ]
    }
  ]
}
